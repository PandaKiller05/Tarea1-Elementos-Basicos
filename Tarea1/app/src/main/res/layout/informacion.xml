<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/mario_background"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ESTADO DEL JUGADOR\n(Información)"
        android:textAlignment="center"
        android:textColor="#C0392B"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estos elementos son de solo lectura. 'TextView' muestra texto estático, 'ImageView' muestra gráficos, y 'ProgressBar' indica un nivel o progreso."
        android:textColor="#333333"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>

    <ImageView
        android:id="@+id/img_avatar"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/mario"
        android:background="#C0392B"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JUGADOR: BRANDON\nCLASE: SPARTAN\nNIVEL: 42"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:lineSpacingExtra="8dp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BARRA DE VIDA (HP):"
        android:textColor="#C0392B"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <ProgressBar
        android:id="@+id/progress_hp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:max="100"
        android:progress="80"
        android:progressTint="#27AE60"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="EXPERIENCIA (XP):"
        android:textColor="#F1C40F"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <ProgressBar
        android:id="@+id/progress_xp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:max="100"
        android:progress="45"
        android:progressTint="#F1C40F" />

</LinearLayout>