<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/mario_background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NUEVO RÉCORD\n(EditText)"
            android:textAlignment="center"
            android:textColor="#C0392B"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Los EditText permiten al jugador ingresar datos de texto o números. Sirven para guardar tu nombre en el High Score o ingresar trucos."
            android:textColor="#333333"
            android:textSize="16sp"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PLAYER 1 - INICIALES (BRN):"
            android:textColor="#C0392B"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_nickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej. AAA (Máx. 3 letras)"
            android:textColorHint="#CCCCCC"
            android:textColor="#333333"
            android:backgroundTint="#C0392B"
            android:inputType="textCapCharacters"
            android:maxLength="3"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>